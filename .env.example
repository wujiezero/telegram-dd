# telegram-dd 环境变量示例
# ---------------------------------------------------------------------------
# 用法：复制为 .env 后按需修改，docker compose 会自动读取同目录下的 .env。
#   cp .env.example .env
# 注意：.env 已在 .gitignore 中忽略，请勿把真实密钥提交到仓库。
# ---------------------------------------------------------------------------

# ========== 必填：Telegram API 凭据 ==========
# 从 https://my.telegram.org (https://core.telegram.org/api/obtaining_api_id) 获取
TELEGRAM_DAEMON_API_ID=
TELEGRAM_DAEMON_API_HASH=

# 要监听下载的频道 ID（整数，通常形如 -1001234567890 或频道内部数字 ID）
TELEGRAM_DAEMON_CHANNEL=

# ========== Web UI 鉴权（强烈建议设置）==========
# 留空 = 开放访问（无需登录，旧行为）。
# 设置后，访问 Web 页面 / API 需要提供该 token。
# 可用如下命令生成一个随机强 token：
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_DAEMON_WEB_TOKEN=

# 通过 HTTPS 反向代理暴露时，把 cookie 的 Secure 标志打开（1=开启）
TELEGRAM_DAEMON_WEB_COOKIE_SECURE=0

# ========== 下载行为 ==========
# 同时下载的 worker 数量（默认等于 CPU 核心数；docker-compose 里默认 2）
TELEGRAM_DAEMON_WORKERS=4

# 重复文件处理策略：ignore（跳过）/ rename（加随机后缀）/ overwrite（覆盖）
TELEGRAM_DAEMON_DUPLICATES=rename

# 单文件多连接并行下载的连接数。
# 跨 DC 场景下并行反而更慢且易触发限流，默认 1（走 Telethon 原生串行下载，最稳）。
# 确认能提速的网络环境下再尝试 2~8。
TELEGRAM_DAEMON_PARALLEL_CONNECTIONS=1

# 仅体积 >= 此值（MB）的文件才走并行下载，小文件并行收益低。
TELEGRAM_DAEMON_PARALLEL_MIN_SIZE_MB=10

# ========== 代理（可选）==========
# DNS 负载均衡的代理域名 + Telegram 报 AUTH_KEY_DUPLICATED 时，建议开启（1=启动时解析一次并固定 IP）
TELEGRAM_DAEMON_PROXY_RESOLVE_ONCE=1

# 需要走代理时取消下面注释并填写
#TELEGRAM_DAEMON_PROXY_HOST=127.0.0.1
#TELEGRAM_DAEMON_PROXY_PORT=7890
#TELEGRAM_DAEMON_PROXY_TYPE=socks5
# 代理需要认证时再填写下面两项
#TELEGRAM_DAEMON_PROXY_USERNAME=
#TELEGRAM_DAEMON_PROXY_PASSWORD=

# ========== 路径（容器内路径，一般无需改动）==========
# 这些已在 docker-compose.yml / Dockerfile 中设置好默认值，仅在自定义挂载时调整。
#TELEGRAM_DAEMON_DEST=/downloads
#TELEGRAM_DAEMON_SESSION_PATH=/session
#TELEGRAM_DAEMON_LOG_DIR=/app/logs
# 某些 NAS/面板的 bind mount 目录可读但不可创建锁文件时，显式指定锁文件路径：
#TELEGRAM_DAEMON_LOCK_FILE=/tmp/DownloadDaemon.lock

# ========== 超时与重试（可选，单位：秒）==========
#TELEGRAM_DAEMON_DOWNLOAD_TIMEOUT=3600       # 单文件下载总超时
#TELEGRAM_DAEMON_START_TIMEOUT=120           # 开始下载超时
#TELEGRAM_DAEMON_NO_PROGRESS_TIMEOUT=300     # 无进度超时
#TELEGRAM_DAEMON_UPDATE_FREQUENCY=10         # 进度更新频率
#TELEGRAM_DAEMON_MAX_RETRIES=3               # 最大重试次数
#TELEGRAM_DAEMON_NOTIFY_FAILURE=1            # 失败时回复通知（1=开启）

# ========== 日志（可选）==========
#TELEGRAM_DAEMON_LOG_LEVEL=INFO              # DEBUG/INFO/WARNING/ERROR
#TELEGRAM_DAEMON_LOG_FILE=telegram-download-daemon.log
#TELEGRAM_DAEMON_LOG_MAX_BYTES=5242880       # 单个日志文件最大字节数（5MB）
#TELEGRAM_DAEMON_LOG_BACKUP_COUNT=5          # 日志轮转保留份数

# ========== Web 跨域（可选）==========
# Socket.IO / API 允许的跨域来源，逗号分隔；留空表示不额外放开。
#TELEGRAM_DAEMON_WEB_CORS_ORIGINS=
